# D&D Beyond Configuration
# Get CHARACTER_ID from URL: https://www.dndbeyond.com/characters/{CHARACTER_ID}/...
# Get COBALT_SESSION from browser DevTools → Network → Find request to character-service.dndbeyond.com
DND_CHARACTER_ID=123456789
DND_COBALT_SESSION=your_cobalt_session_cookie_here

# OBS WebSocket Configuration
# Default is usually correct if OBS is running locally
OBS_WEBSOCKET_URL=ws://localhost:4455
# Leave blank if no password is set in OBS
OBS_WEBSOCKET_PASSWORD=

# Polling Configuration
# Interval in milliseconds between character sheet updates (default: 5000)
# Minimum recommended: 3000 (to be respectful to D&D Beyond API)
POLL_INTERVAL_MS=5000

# OBS Mode: "image_swap" or "visibility_toggle"
# image_swap: Changes the image source's file path
# visibility_toggle: Toggles visibility of scene items named: healthy, scratched, bloodied, dying, unconscious
OBS_MODE=visibility_toggle

# ===== For visibility_toggle mode =====
# Name of the scene containing the HP state items
OBS_SCENE_NAME=D&D Overlay

# ===== For image_swap mode =====
# Name of the image source to swap
OBS_SOURCE_NAME=Character_Portrait

# Image paths for each HP state (for image_swap mode)
# Use forward slashes or escaped backslashes (e.g., C:/obs-images/file.png)
OBS_IMAGE_HEALTHY=C:/obs-images/character_healthy.png
OBS_IMAGE_SCRATCHED=C:/obs-images/character_scratched.png
OBS_IMAGE_BLOODIED=C:/obs-images/character_bloodied.png
OBS_IMAGE_DYING=C:/obs-images/character_dying.png
OBS_IMAGE_UNCONSCIOUS=C:/obs-images/character_unconscious.png

# ===== Stat Display Configuration =====
# Map D&D Beyond stats to OBS text sources
# Format: STAT_MAPPING_<N>=<stat_id>:<obs_source_name>[:<format>]
# 
# Available stats: level, ac, hp_current, hp_max, hp_temp, hp_display,
#   strength, strength_mod, dexterity, dexterity_mod, constitution, constitution_mod,
#   intelligence, intelligence_mod, wisdom, wisdom_mod, charisma, charisma_mod,
#   proficiency, passive_perception, passive_investigation, passive_insight,
#   initiative, speed, spell_save_dc, spell_attack
#
# Examples (uncomment to enable):
# STAT_MAPPING_1=ac:Text_AC:AC {value}
# STAT_MAPPING_2=hp_display:Text_HP
# STAT_MAPPING_3=level:Text_Level:Lvl {value}
# STAT_MAPPING_4=passive_perception:Text_PassivePerception:PP {value}
# STAT_MAPPING_5=initiative:Text_Initiative:{value}

# ===== Game Log Configuration (Dice Rolls) =====
# Enable game log polling for dice roll display
GAME_LOG_ENABLED=false

# Game/Campaign ID from D&D Beyond (found in campaign URL or API calls)
GAME_LOG_GAME_ID=

# Your D&D Beyond User ID (to filter to only your rolls)
GAME_LOG_USER_ID=

# Poll interval for game log (can be faster than character polling)
GAME_LOG_POLL_INTERVAL_MS=3000

# Last Roll Display - shows most recent roll
# Source name in OBS (leave empty to disable)
LAST_ROLL_SOURCE=
# Format string with placeholders: {character}, {action}, {total}, {breakdown}, {roll_type}, {roll_kind}, {dice}, {values}
LAST_ROLL_FORMAT={action}: {total}

# Roll History Display - shows last X rolls
# Source name in OBS (leave empty to disable)
ROLL_HISTORY_SOURCE=
# Format for each line
ROLL_HISTORY_FORMAT={action} {total}
# Number of rolls to show
ROLL_HISTORY_COUNT=5

# ===== Debug Settings =====
# Save API response to api-response.json on each poll (useful for debugging)
# Default: false (disabled to avoid writing 40k+ lines of JSON every poll)
DEBUG_SAVE_API_RESPONSE=false