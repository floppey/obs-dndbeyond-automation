# D&D Beyond Configuration
# Get CHARACTER_ID from URL: https://www.dndbeyond.com/characters/{CHARACTER_ID}/...
# Get COBALT_SESSION from browser DevTools → Network → Find request to character-service.dndbeyond.com
DND_CHARACTER_ID=123456789
DND_COBALT_SESSION=your_cobalt_session_cookie_here

# OBS WebSocket Configuration
# Default is usually correct if OBS is running locally
OBS_WEBSOCKET_URL=ws://localhost:4455
# Leave blank if no password is set in OBS
OBS_WEBSOCKET_PASSWORD=

# Polling Configuration
# Interval in milliseconds between character sheet updates (default: 5000)
# Minimum recommended: 3000 (to be respectful to D&D Beyond API)
POLL_INTERVAL_MS=5000

# OBS Mode: "image_swap" or "visibility_toggle"
# image_swap: Changes the image source's file path
# visibility_toggle: Toggles visibility of scene items named: healthy, scratched, bloodied, dying, unconscious
OBS_MODE=visibility_toggle

# ===== For visibility_toggle mode =====
# Name of the scene containing the HP state items
OBS_SCENE_NAME=D&D Overlay

# ===== For image_swap mode =====
# Name of the image source to swap
OBS_SOURCE_NAME=Character_Portrait

# Image paths for each HP state (for image_swap mode)
# Use forward slashes or escaped backslashes (e.g., C:/obs-images/file.png)
OBS_IMAGE_HEALTHY=C:/obs-images/character_healthy.png
OBS_IMAGE_SCRATCHED=C:/obs-images/character_scratched.png
OBS_IMAGE_BLOODIED=C:/obs-images/character_bloodied.png
OBS_IMAGE_DYING=C:/obs-images/character_dying.png
OBS_IMAGE_UNCONSCIOUS=C:/obs-images/character_unconscious.png
