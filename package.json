{
  "name": "obs-dndbeyond-automation",
  "version": "1.0.0",
  "description": "Automatically sync OBS images with D&D Beyond character HP in real-time",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "build:exe": "node scripts/build-exe.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist dist-cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obs",
    "obs-studio",
    "d&d-beyond",
    "automation",
    "streaming",
    "d&d",
    "dnd"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.0.3",
    "obs-websocket-js": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.4.5",
    "esbuild": "^0.27.2",
    "pkg": "^5.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.1.6",
    "vitest": "^4.0.17"
  },
  "pkg": {
    "targets": ["node18-win-x64"],
    "outputPath": "release"
  }
}
